{
  "export": "out",
  "nodeModulesDir": "auto",
  "unstable": [
    "unsafe-proto"
  ],
  "imports": {
    "next": "npm:next@16.2.2",
    "next/": "npm:next@16.2.2/"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "strict": true,
    "jsx": "preserve"
  },
  "lint": {
    "rules": {
      "exclude": ["no-process-global"]
    }
  },
  "tasks": {
    "dev": "deno run -A --unstable-detect-cjs npm:next@16.2.2 dev",
    "build": "deno run -A --unstable-detect-cjs npm:next@16.2.2 build",
    "start": "deno run -A --unstable-detect-cjs npm:next@16.2.2 start",
    "lint": "deno lint --fix && deno fmt --check"
  }
}
