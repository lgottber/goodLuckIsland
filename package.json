{
  "name": "tutorial-with-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:cf": "next build && npx @cloudflare/next-on-pages",
    "preview": "npm run build:cf && wrangler pages dev --ip '127.0.0.1' .vercel/output/static",
    "deploy:production": "wrangler pages deploy .vercel/output/static --project-name good-luck-island --branch main",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "postinstall": "patch-package",
    "format:check": "prettier --check .",
    "tf:init": "terraform -chdir=terraform init",
    "tf:plan": "terraform -chdir=terraform plan",
    "tf:apply": "terraform -chdir=terraform apply -auto-approve",
    "tf:destroy": "terraform -chdir=terraform destroy -auto-approve",
    "tf:import-pages": "terraform -chdir=terraform import cloudflare_pages_project.app $CLOUDFLARE_ACCOUNT_ID/good-luck-island",
    "secrets:sync": "gh secret set -f .env.local",
    "secrets:delete-all": "gh secret list | awk '{print $1}' | xargs -I {} gh secret delete {}"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.2.4",
    "@auth0/auth0-spa-js": "^2.1.3",
    "@supabase/supabase-js": "^2.101.1",
    "next": "15.5.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260501.1",
    "@types/node": "^20.19.26",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.0.0",
    "supabase": "^2.91.2",
    "typescript": "6.0.2",
    "wrangler": "^4.85.0"
  }
}
