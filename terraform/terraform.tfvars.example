cloudflare_api_token  = "your-cloudflare-api-token"
cloudflare_account_id = "your-account-id"
cloudflare_zone_id    = "your-zone-id"
project_name          = "good-luck-island"
subdomain             = "@"
custom_domain         = "goodluckisland.com"

# App environment variables (injected into Cloudflare Pages builds)
next_public_auth0_domain             = "your-tenant.us.auth0.com"
next_public_auth0_client_id          = "your-auth0-client-id"
next_public_shopify_store_domain     = "your-store.myshopify.com"
next_public_shopify_storefront_token = "your-storefront-token"
next_public_shopify_collection_id    = "gid://shopify/Collection/your-id"

# Access login page branding (defaults match the app palette — override if needed)
# access_logo_url        = "https://yourdomain.com/logo.png"
# access_bg_color        = "#f0ebe0"
# access_header_bg_color = "#1e2d5a"
